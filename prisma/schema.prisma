generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @db.VarChar(40)
  role           String    @default("CLIENT") @db.VarChar(20)
  name           String?
  email          String?   @unique
  password_hash  String?   @map("password_hash")
  phone          String?
  birth_date     DateTime? @map("birth_date") @db.Date
  hair_type      String?   @map("hair_type")
  hair_texture   String?   @map("hair_texture")
  has_beard      Boolean?  @map("has_beard")
  created_at     DateTime? @map("created_at")
  updated_at     DateTime? @map("updated_at")

  barber             Barber?
  ownedBarbershops   Barbershop[]        @relation("OwnerBarbershops")
  appointments       Appointment[]
  favorites          Favorite[]
  documents          UserDocument[]
  paymentMethods     UserPaymentMethod[]
  preferences        UserPreferences?
  termsAcceptances   TermsAcceptance[]
}

model Barber {
  id                String    @id @db.VarChar(40)
  user_id           String?   @unique @map("user_id") @db.VarChar(40)
  name              String?
  bio               String?
  years_experience  Int?      @map("years_experience")
  rating            Decimal?  @db.Decimal(12, 2)
  created_at        DateTime? @map("created_at")
  updated_at        DateTime? @map("updated_at")

  user                User?                @relation(fields: [user_id], references: [id])
  barbershopBarbers   BarbershopBarber[]
  appointments        Appointment[]
  favorites           Favorite[]
  barberServices      BarberServiceLink[]
  portfolio           BarberPortfolio[]
  availability        BarberAvailability[]
}

model Barbershop {
  id                     String    @id @db.VarChar(40)
  owner_user_id          String?   @map("owner_user_id") @db.VarChar(40)
  name                   String?
  cnpj                   String?
  description            String?
  phone                  String?
  email                  String?
  address                String?
  neighborhood           String?
  city                   String?
  state                  String?
  opening_time           DateTime? @map("opening_time") @db.Time(6)
  closing_time           DateTime? @map("closing_time") @db.Time(6)
  is_active              Boolean   @default(true) @map("is_active")
  is_headquarter         Boolean   @default(true) @map("is_headquarter")
  parent_barbershop_id   String?   @map("parent_barbershop_id") @db.VarChar(40)
  created_at             DateTime? @map("created_at")
  updated_at             DateTime? @map("updated_at")

  owner          User?              @relation("OwnerBarbershops", fields: [owner_user_id], references: [id])
  parent         Barbershop?        @relation("BarbershopBranches", fields: [parent_barbershop_id], references: [id])
  children       Barbershop[]       @relation("BarbershopBranches")
  photos         BarbershopPhoto[]
  barbershopBarbers BarbershopBarber[]
  barbershopServices BarbershopServiceLink[]
  appointments   Appointment[]
  favorites      Favorite[]
}

model BarbershopPhoto {
  id            String    @id @db.VarChar(40)
  barbershop_id String?   @map("barbershop_id") @db.VarChar(40)
  image_url     String?   @map("image_url")
  created_at    DateTime? @map("created_at")

  barbershop Barbershop? @relation(fields: [barbershop_id], references: [id])
}

model BarbershopBarber {
  id            String   @id @db.VarChar(40)
  barbershop_id String   @map("barbershop_id") @db.VarChar(40)
  barber_id     String   @map("barber_id") @db.VarChar(40)
  active        Boolean?

  barbershop Barbershop @relation(fields: [barbershop_id], references: [id])
  barber     Barber     @relation(fields: [barber_id], references: [id])
}

model CatalogService {
  id               String    @id @db.VarChar(40)
  name             String?
  description      String?
  base_price       Decimal?  @map("base_price") @db.Decimal(12, 2)
  duration_minutes Int?      @map("duration_minutes")

  barbershopLinks BarbershopServiceLink[]
  barberLinks     BarberServiceLink[]
  appointments    Appointment[]

  @@map("services")
}

model BarbershopServiceLink {
  id             String    @id @db.VarChar(40)
  barbershop_id  String?   @map("barbershop_id") @db.VarChar(40)
  service_id     String?   @map("service_id") @db.VarChar(40)
  custom_price   Decimal?  @map("custom_price") @db.Decimal(12, 2)

  barbershop Barbershop?     @relation(fields: [barbershop_id], references: [id])
  service    CatalogService? @relation(fields: [service_id], references: [id])

  @@map("barbershop_services")
}

model BarberServiceLink {
  id         String @id @db.VarChar(40)
  barber_id  String @map("barber_id") @db.VarChar(40)
  service_id String @map("service_id") @db.VarChar(40)

  barber  Barber         @relation(fields: [barber_id], references: [id])
  service CatalogService @relation(fields: [service_id], references: [id])

  @@map("barber_services")
}

model BarberPortfolio {
  id         String    @id @db.VarChar(40)
  barber_id  String?   @map("barber_id") @db.VarChar(40)
  image_url  String?   @map("image_url")
  hair_type  String?   @map("hair_type")
  style_tag  String?   @map("style_tag")
  created_at DateTime? @map("created_at")

  barber Barber? @relation(fields: [barber_id], references: [id])

  @@map("barber_portfolio")
}

model BarberAvailability {
  id         String    @id @db.VarChar(40)
  barber_id  String?   @map("barber_id") @db.VarChar(40)
  weekday    Int?
  start_time DateTime? @map("start_time") @db.Time(6)
  end_time   DateTime? @map("end_time") @db.Time(6)

  barber Barber? @relation(fields: [barber_id], references: [id])

  @@map("barber_availability")
}

model Appointment {
  id                   String    @id @db.VarChar(40)
  user_id              String?   @map("user_id") @db.VarChar(40)
  barbershop_id        String?   @map("barbershop_id") @db.VarChar(40)
  barber_id            String?   @map("barber_id") @db.VarChar(40)
  service_id           String?   @map("service_id") @db.VarChar(40)
  scheduled_at         DateTime? @map("scheduled_at")
  completed_at         DateTime? @map("completed_at")
  status               String
  cancellation_reason  String?   @map("cancellation_reason")
  final_price          Decimal?  @map("final_price") @db.Decimal(12, 2)
  payment_method       String?   @map("payment_method")
  created_at           DateTime? @map("created_at")

  user       User?           @relation(fields: [user_id], references: [id])
  barbershop Barbershop?     @relation(fields: [barbershop_id], references: [id])
  barber     Barber?         @relation(fields: [barber_id], references: [id])
  service    CatalogService? @relation(fields: [service_id], references: [id])
}

model Favorite {
  id            String    @id @db.VarChar(40)
  user_id       String?   @map("user_id") @db.VarChar(40)
  barber_id     String?   @map("barber_id") @db.VarChar(40)
  barbershop_id String?   @map("barbershop_id") @db.VarChar(40)
  created_at    DateTime? @map("created_at")

  user       User?       @relation(fields: [user_id], references: [id])
  barber     Barber?     @relation(fields: [barber_id], references: [id])
  barbershop Barbershop? @relation(fields: [barbershop_id], references: [id])
}

model UserDocument {
  id              String    @id @db.VarChar(40)
  user_id         String?   @map("user_id") @db.VarChar(40)
  document_type   String?   @map("document_type")
  document_number String?   @map("document_number")
  created_at      DateTime? @map("created_at")

  user User? @relation(fields: [user_id], references: [id])

  @@map("user_documents")
}

model UserPaymentMethod {
  id                     String    @id @db.VarChar(40)
  user_id                String?   @map("user_id") @db.VarChar(40)
  provider               String?
  provider_customer_id   String?   @map("provider_customer_id")
  card_type              String?   @map("card_type") @db.VarChar(10)
  last_four_digits       String?   @map("last_four_digits") @db.VarChar(4)
  brand                  String?   @db.VarChar(30)
  created_at             DateTime? @map("created_at")

  user User? @relation(fields: [user_id], references: [id])

  @@map("user_payment_methods")
}

model UserPreferences {
  id         String    @id @db.VarChar(40)
  user_id    String    @unique @map("user_id") @db.VarChar(40)
  theme      String    @default("LIGHT") @db.VarChar(10)
  language   String    @default("pt-BR") @db.VarChar(10)
  updated_at DateTime? @map("updated_at")

  user User @relation(fields: [user_id], references: [id])

  @@map("user_preferences")
}

model TermsAcceptance {
  id             String   @id @db.VarChar(40)
  user_id        String   @map("user_id") @db.VarChar(40)
  terms_version  String   @map("terms_version") @db.VarChar(20)
  accepted_at    DateTime @map("accepted_at")

  user User @relation(fields: [user_id], references: [id])

  @@map("terms_acceptances")
}

model RevokedToken {
  id         String   @id @db.VarChar(36)
  token      String   @unique @db.VarChar(512)
  revoked_at DateTime @map("revoked_at")

  @@map("revoked_tokens")
}
