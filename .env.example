# PostgreSQL (same DB as legacy Flyway migrations)
# Local sem SSL: ?sslmode=disable
# Supabase / Render / qualquer host na internet: OBRIGATÓRIO SSL — usa o URI do dashboard do Supabase ou:
#   ?sslmode=require
# (sslmode=disable em produção com Supabase costuma falhar ou dar P1001 "Can't reach database server".)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET=dev-only-change-me-use-32chars-minimum!!
JWT_EXPIRATION_MS=86400000

# Default 8080 matches barberfind-mobile examples
PORT=8080

# Comma-separated origins
CORS_ORIGINS=http://localhost:5173

# --- Render / keep-alive (optional) ---
# Log + optional HTTP self-ping every 30s (see KeepAliveService).
# On Render Free, only incoming HTTP delays spin-down; set ENABLE_KEEP_ALIVE_PING=true
# so the app GETs its own public URL (RENDER_EXTERNAL_URL is set by Render Web Services).

# ENABLE_KEEP_ALIVE_PING=true
# KEEP_ALIVE_URL=https://your-service.onrender.com/api/ping
# (If unset, RENDER_EXTERNAL_URL + /api/ping is used when ENABLE_KEEP_ALIVE_PING=true)
